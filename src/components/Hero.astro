---
const heroImg = "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=2200&q=85&auto=format&fit=crop";
---

<header class="hero" id="top">
  <div class="hero-bg">
    <img src={heroImg} alt="" loading="eager" fetchpriority="high" />
  </div>
  <div class="container">
    <div class="hero-top">
      <span><span class="dot"></span>Estudio activo · Santiago, Chile</span>
      <span>Edición N.º 24 / 2026</span>
    </div>
    <div class="hero-content">
      <div class="hero-eyebrow">Edición fotográfica inmobiliaria</div>
      <h1 class="serif" data-reveal>
        Fotos inmobiliarias <em>que venden</em><br />mejor.
      </h1>
      <p class="hero-sub" data-reveal>
        Editamos tus fotos, creamos carruseles para Instagram y preparamos publicaciones
        listas para portales inmobiliarios. Tus departamentos al nivel de las grandes marcas.
      </p>
      <div class="hero-ctas" data-reveal>
        <a href="#cotizar" class="btn btn-primary">
          Enviar fotos para cotizar <span class="btn-arrow"></span>
        </a>
        <a href="#trabajos" class="btn btn-ghost">Ver ejemplos</a>
      </div>
    </div>
  </div>
</header>

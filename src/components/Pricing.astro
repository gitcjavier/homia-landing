---
const plans = [
  {
    key: "basico",
    eyebrow: "Básico",
    title: "Edición",
    price: "49",
    desc: "Para publicar propiedades con fotos limpias y profesionales.",
    feats: [
      "Hasta 15 fotos editadas",
      "Corrección de luz, color y líneas",
      "Encuadre para portales y redes",
      "Entrega en 48 horas",
    ],
    cta: "Pedir Básico",
    ctaClass: "btn-ghost",
    featured: false,
  },
  {
    key: "pro",
    eyebrow: "Más elegido",
    title: "Pro",
    price: "89",
    desc: "Edición + texto persuasivo listo para subir a portales.",
    feats: [
      "Hasta 25 fotos editadas",
      "Edición premium con retoque selectivo",
      "Descripción persuasiva en 2 versiones",
      "Adaptación para Mercado Libre",
      "Entrega en 24 horas",
    ],
    cta: "Pedir Pro",
    ctaClass: "btn-primary",
    featured: true,
  },
  {
    key: "premium",
    eyebrow: "Premium",
    title: "Estudio",
    price: "149",
    desc: "El paquete completo para campañas que tienen que rendir.",
    feats: [
      "Hasta 40 fotos editadas",
      "Carrusel Instagram de 4 a 10 slides",
      "Descripción + caption para redes",
      "Adaptación para todos los portales",
      "Revisión de cambios incluida",
      "Entrega prioritaria 24 horas",
    ],
    cta: "Pedir Estudio",
    ctaClass: "btn-ghost",
    featured: false,
  },
];
---

<section class="section-pad" id="planes">
  <div class="container">
    <div class="s-head" data-reveal>
      <h2 class="serif">Planes <em>simples,</em> precios claros.</h2>
      <p class="s-intro">
        Por propiedad, sin contratos ni mensualidades. Si trabajas con volumen, te armamos un
        plan a medida con descuento por cartera.
      </p>
    </div>
    <div class="pricing-grid" data-reveal>
      {plans.map((p) => (
        <div class={`plan ${p.featured ? 'featured' : ''}`}>
          {p.featured && <div class="p-tag">{p.eyebrow}</div>}
          {!p.featured && <div class="p-eyebrow">{p.eyebrow}</div>}
          <div class="p-title serif">{p.title}</div>
          <p class="p-desc">{p.desc}</p>
          <div class="p-price serif">
            <span class="p-currency">UF</span>{p.price}
            <span class="p-suffix">por propiedad</span>
          </div>
          <ul class="p-feats">
            {p.feats.map((f) => <li>{f}</li>)}
          </ul>
          <a href="#cotizar" class={`btn ${p.ctaClass}`}>
            {p.cta} <span class="btn-arrow"></span>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
